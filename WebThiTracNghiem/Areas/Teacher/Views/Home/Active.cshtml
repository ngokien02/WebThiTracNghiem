@model List<DeThi>
    <div class="page-header">
        <h1>Kỳ thi đang diễn ra</h1>
        <div class="header-actions">
        <a href="teacher/exam" class="btn primary CreateExam">
                <i class="fas fa-plus"></i> Tạo kỳ thi mới
            </a>
        </div>
    </div>

    <!-- Exam Filters -->
    <div class="exam-filters">
        <select class="filter-select">
            <option value="">Tất cả môn học</option>
            <option value="auto">Kỹ thuật Sửa chữa Ô tô</option>
            <option value="safety">An toàn Giao thông</option>
            <option value="logistics">Quản lý Kho vận</option>
        </select>
        <select class="filter-select">
            <option value="">Tất cả học kỳ</option>
            <option value="20242">HK2 (2024-2025)</option>
            <option value="20241">HK1 (2024-2025)</option>
        </select>
        <div class="search-box">
            <input type="text" placeholder="Tìm kiếm bài thi...">
            <button><i class="fas fa-search"></i></button>
        </div>
    </div>

        <!-- Exam Card 1 -->
        @foreach (var deThi in Model)
        {
            <div class="exam-management-card">
                <div class="exam-header">
                    <h3>@deThi.TieuDe</h3>
                    <span class="exam-code">Mã đề: @deThi.MaDe</span>
                    <span class="exam-status @(deThi.GioBD > DateTime.Now ? "upcoming" : "active")">@(deThi.GioBD > DateTime.Now ? "Sắp diễn ra" : "Đang diễn ra")</span>
                </div>
                <div class="exam-details">
                    <p><i class="fas fa-calendar"></i> Bắt đầu: @deThi.GioBD.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><i class="fas fa-calendar-check"></i> Kết thúc: @deThi.GioKT.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><i class="fas fa-clock"></i> Thời gian: @deThi.ThoiGian phút</p>
                    <p><i class="fas fa-star"></i> Điểm tối đa: @deThi.DiemToiDa</p>
                    <p class="full-width"><i class="fas fa-chalkboard-teacher"></i> GV: @deThi.GiangVien.HoTen</p>
                </div>
            </div>
        }