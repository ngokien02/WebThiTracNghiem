@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}
<h1>@ViewData["Title"]</h1>
<h2>Enter your email.</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="form-label"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary">Reset Password</button>
        </form>
    </div>
</div>


    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $("#btnSendReset").on("click", function (e) {
            e.preventDefault(); // Ngăn submit ngay

            const email = $("#inputEmail").val().trim();
            if (!email) {
                Swal.fire("⚠️ Lỗi", "Vui lòng nhập email!", "warning");
                return;
            }

            $.get("/Email/CheckExist", { email: email })
                .done(res => {
                    if (res.exists) {
                        // ✅ Email hợp lệ → submit form
                        $("#forgot-password-form")[0].submit();
                    } else {
                        // ❌ Không tồn tại trong hệ thống
                        Swal.fire("❌ Email không tồn tại", "Vui lòng nhập email đã đăng ký tài khoản.", "error");
                    }
                })
                .fail(() => {
                    Swal.fire("❌ Lỗi", "Không thể kiểm tra email lúc này.", "error");
                });
        });
    </script>

    @if (TempData["EmailSent"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Đã gửi email!',
                text: 'Vui lòng kiểm tra email để đặt lại mật khẩu.',
                confirmButtonText: 'OK'
            });
        </script>
    }
}

